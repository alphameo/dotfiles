% Empty Box
\newtcolorbox{myemptybox}[1]
{
	frame hidden,
	titlerule=0mm,
	toptitle=1mm,
	bottomtitle=1mm,
	coltitle=black,
	colbacktitle=red!30!white,
	colback=red!20!white,
	colframe=red!30!white,
	title=\bfseries #1
}

\NewDocumentCommand{\ebox}{m+m}{
	\begin{myemptybox}{#1}{
		\raggedright#2
		}
	\end{myemptybox}
}

