% Example
\newenvironment{example}{
	\par
	\vspace{5pt}
	\noindent\textbf{Пример}
	\begin{tcolorbox}[
			blanker, breakable, left=5mm, parbox=false,
			before upper={\parindent15pt},
			after skip=10pt,
			borderline west={1mm}{0pt}{cyan!10!white}]
		}{
	\end{tcolorbox}
	\vspace{5pt}
}

\NewDocumentCommand{\ex}{+m}{
	\begin{example}
		\raggedright#1
	\end{example}
}

