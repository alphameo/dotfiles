\usepackage{tcolorbox}
\tcbuselibrary{theorems,skins,breakable}
% Theorem System
% The following boxes are provided:
%   Опр.:           \defn{title}{content}
%   Теорема:        \thm{title}{content}
%   Лемма:          \lem{title}{content}
%   Формула:        \frm{title}{content}
%   Следствие:      \cor{content}
%   Утверждение:    \prop{content}
%   Пустая зона:    \ebox{title}{content}
%   Claim:          \clm{}{content}{ref}
%   Факт:           \fact{content}
%   Док-во:         \pf
%   Пример:         \ex{content}
%   Замечание:      \rmk{content} (sentence), \rmkb{content} (block)
% Suffix
%   r:              Allow Theorem/Definition to be referenced, e.g. thmr
%   p:              Add a short proof block for Lemma, Corollary, Proposition or Claim, e.g. lemp
%                   For theorems, use \pf for proof blocks

% Definition
\newtcbtheorem[no counter]{mydefinition}{\bfseries Опр.}
{
	enhanced,
	titlerule=0mm,
	toptitle=1mm,
	bottomtitle=1mm,
	coltitle=black,
	colbacktitle=green!20!white,
	colback=green!10!white,
	colframe=green!20!white,
}{defn}

\NewDocumentCommand{\defn}{m+m}{
	\begin{mydefinition}{#1}{}
	#2
	\end{mydefinition}
}

\NewDocumentCommand{\defnr}{mm+m}{
	\begin{mydefinition}{\underline{#1}}{#2}
	#3
	\end{mydefinition}
}

% Theorem
\newtcbtheorem[no counter]{mytheorem}{\bfseries Теорема}
{
	enhanced,
	titlerule=0mm,
	toptitle=1mm,
	bottomtitle=1mm,
	coltitle=black,
	colbacktitle=cyan!40!white,
	colback=cyan!20!white,
	colframe=cyan!40!white,
}{thm}

\NewDocumentCommand{\thm}{m+m}{
	\begin{mytheorem}{#1}{}
		\raggedright#2
	\end{mytheorem}
}

\NewDocumentCommand{\thmr}{mm+m}{
	\begin{mytheorem}{#1}{#2}
		\raggedright#3
	\end{mytheorem}
}
\newenvironment{thmpf}{
	{\noindent{\it \textbf{Доказательство}}}
	\tcolorbox[blanker,breakable,left=5mm,parbox=false,
		before upper={\parindent15pt},
		after skip=10pt,
		borderline west={1mm}{0pt}{cyan!40!white}]
}{
	\textcolor{cyan!40!white}{\hbox{}\nobreak\hfill$\blacksquare$}
	\endtcolorbox
}

\NewDocumentCommand{\thmp}{m+m+m}{
	\begin{mytheorem}{#1}{}
		\raggedright#2
	\end{mytheorem}

	\begin{thmpf}
		\raggedright#3
	\end{thmpf}
}

